{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "flutter: mobile web on 8091",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"chrome",
				"--web-hostname=127.0.0.1",
				"--web-port=8091"
			],
			"options": {
				"cwd": "${workspaceFolder}/mobile_app"
			},
			"isBackground": true,
			"group": "build"
		}
	]
}